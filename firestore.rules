rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "moonjiugi917@gmail.com"
        && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    match /store/catalog {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /store/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 현재 비회원 주문 구조에서는 고객의 주문 생성·조회에 이 문서가 필요합니다.
    // 주문별 문서와 익명 인증으로 전환한 뒤 관리자 전용 규칙으로 강화할 수 있습니다.
    match /store/orders {
      allow read, write: if true;
    }

    match /productImages/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
